{
    "name": "backend",
    "version": "1.0.0",
    "main": "src/index.ts",
    "scripts": {
        "studio": "npx prisma studio",
        "build": "tsc",
        "seed": "ts-node --transpile-only src/seed.ts",
        "db:snapshot": "ts-node --transpile-only src/scripts/snapshot.ts",
        "db:snapshot:core": "ts-node --transpile-only src/scripts/snapshot.ts --core",
        "db:restore": "ts-node --transpile-only src/scripts/restore.ts",
        "db:migrate:safe": "npm run db:snapshot && npx prisma migrate dev",
        "db:reset:safe": "npm run db:snapshot && npx prisma migrate reset --force",
        "migrate": "npx prisma migrate dev",
        "start": "node dist/index.js",
        "dev": "nodemon --watch src --ext ts --exec ts-node --transpile-only src/index.ts",
        "generate": "npx prisma generate"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "@prisma/client": "^6.19.3",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^17.4.0",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.2",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.20.0",
        "resend": "^6.10.0",
        "uuid": "^13.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.5.2",
        "@types/uuid": "^10.0.0",
        "nodemon": "^3.1.14",
        "prisma": "^6.19.3",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2"
    }
}
